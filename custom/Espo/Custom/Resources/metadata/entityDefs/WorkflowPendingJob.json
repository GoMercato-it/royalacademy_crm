            "type": "varchar",
            "required": true,
            "len": 50,
            "index": true
        },
        "workflowExecutionId": {
            "type": "varchar",
            "len": 50,
            "index": true
        },
        "triggerType": {
            "type": "varchar",
            "len": 100,
            "index": true
        },
        "relatedEntityType": {
            "type": "varchar",
            "len": 100,
            "index": true
        },
        "relatedEntityId": {
            "type": "varchar",
            "len": 50,
            "index": true
        },
        "status": {
            "type": "enum",
            "options": ["queued", "running", "completed", "failed", "cancelled"],
