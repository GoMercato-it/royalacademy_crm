{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views\/fields\/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views\/fields\/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views\/fields\/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views\/fields\/teams"
        },
        "student": {
            "type": "link",
            "required": true
        },
        "course": {
            "type": "link",
            "required": true
        },
        "isActive": {
            "type": "bool",
            "default": true
        },
        "assignedAt": {
            "type": "datetime"
        },
        "courseCompleted": {
            "type": "bool",
            "default": false
        },
        "completedAt": {
            "type": "datetime"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "student": {
            "type": "belongsTo",
            "entity": "Student",
            "foreign": "courseAccesses"
        },
        "course": {
            "type": "belongsTo",
            "entity": "Course",
            "foreign": "courseAccesses"
        }
    },
    "collection": {
        "sortBy": "createdAt",
        "asc": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}