{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views\/fields\/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views\/fields\/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views\/fields\/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views\/fields\/teams"
        },
        "user": {
            "type": "link",
            "unique": true
        },
        "firstName": {
            "type": "varchar"
        },
        "lastName": {
            "type": "varchar"
        },
        "dateOfBirth": {
            "type": "date"
        },
        "phone": {
            "type": "phone",
            "typeList": ["Mobile", "Office", "Home", "Fax", "Other", "WhatsApp"]
        },
        "email": {
            "type": "email"
        },
        "address": {
            "type": "text"
        },
        "city": {
            "type": "varchar"
        },
        "country": {
            "type": "varchar"
        },
        "languagePreference": {
            "type": "enum",
            "options": [
                "Italiano",
                "English",
                "Russian"
            ]
        },
        "enrollmentDate": {
            "type": "date"
        },
        "status": {
            "type": "enum",
            "options": [
                "Attiva",
                "Inattiva",
                "Diplomata",
                "Sospesa",
                "Espulsa"
            ]
        },
        "notes": {
            "type": "text"
        },
        "emergencyContact": {
            "type": "varchar"
        },
        "emergencyPhone": {
            "type": "phone",
            "typeList": ["Mobile", "Office", "Home", "Fax", "Other", "WhatsApp"]
        },
        "educationLevel": {
            "type": "enum",
            "options": [
                "Licenza media",
                "Diploma",
                "Laurea"
            ]
        },
        "previousExperience": {
            "type": "text"
        },
        "instagram": {
            "type": "varchar"
        },
        "portfolioUrl": {
            "type": "url"
        },
        "profilePhotoKey": {
            "type": "varchar",
            "readOnly": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "user": {
            "type": "belongsTo",
            "entity": "User"
        },
        "courseAccesses": {
            "type": "hasMany",
            "entity": "CourseAccess",
            "foreign": "student"
        }
    },
    "collection": {
        "sortBy": "createdAt",
        "asc": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}
