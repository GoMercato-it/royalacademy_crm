{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "status": {
            "type": "enum",
            "options": [
                "Bozza",
                "Attivo",
                "Archiviato"
            ],
            "default": "Bozza"
        },
        "category": {
            "type": "enum",
            "options": [
                "Professional",
                "Masterclass",
                "Workshop",
                "Online"
            ]
        },
        "durationHours": {
            "type": "int"
        },
        "price": {
            "type": "currency"
        },
        "coverImageKey": {
            "type": "varchar",
            "readOnly": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "sections": {
            "type": "hasMany",
            "entity": "CourseSection",
            "foreign": "course",
            "audited": false
        },
        "courseAccesses": {
            "type": "hasMany",
            "entity": "CourseAccess",
            "foreign": "course"
        }
    },
    "collection": {
        "sortBy": "createdAt",
        "asc": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}