{
    "controller": "controllers/record",
    "iconClass": "fas fa-project-diagram",
    "dynamicLogic": {
        "fields": {
            "updateRecurrenceMode": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "or",
                            "value": [
                                {
                                    "type": "equals",
                                    "attribute": "triggerType",
                                    "value": "record_updated"
                                },
                                {
                                    "type": "equals",
                                    "attribute": "triggerType",
                                    "value": "record_saved_including_create"
                                }
                            ]
                        }
                    ]
                }
            },
            "scheduling": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "equals",
                            "attribute": "triggerType",
                            "value": "scheduled"
                        }
                    ]
                }
            }
        }
    }
}
